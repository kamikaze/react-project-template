    "build:dev": "VITE_STAGE=dev tsc -b && VITE_STAGE=dev vite build",
    "build:prod": "VITE_STAGE=prod tsc -b && VITE_STAGE=prod vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "react-oidc-context": "^3.3.1",
