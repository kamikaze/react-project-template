{
  "name": "react-project-template",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "VITE_STAGE=local vite",
    "dev:dev": "VITE_STAGE=dev vite",
    "dev:prod": "VITE_STAGE=prod vite",
    "build": "tsc -b && vite build",
